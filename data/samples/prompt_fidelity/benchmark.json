{
  "name": "prompt_fidelity_mixed_v2_hard",
  "image_dir": "data/samples/prompt_fidelity/images",
  "notes": "Harder mixed benchmark for separating free-form captions from structured representations. It expands the original benchmark with sibling UI screens, same-family disambiguation queries, paraphrases, partial cues, visible-text-sensitive prompts, layout-sensitive prompts, and hard negatives.",
  "query_tag_taxonomy": {
    "ui_family_disambiguation": "Queries that must distinguish visually and semantically similar UI screens from the same product family.",
    "visible_text": "Queries where exact or near-exact visible words, labels, titles, or short phrases should drive retrieval.",
    "layout_structure": "Queries where screen layout, panels, cards, sidebars, or section arrangement should drive retrieval.",
    "person_name": "Queries that rely on a visible or implied person/entity name such as Albert Einstein or Cleopatra.",
    "paraphrase": "Queries that describe the target with different wording from the likely caption.",
    "photo_scene": "Queries for real-world photo scene understanding.",
    "illustration_style": "Queries that rely on drawn or painted visual style.",
    "partial_cue": "Queries that provide only a few discriminative cues rather than a full scene description.",
    "hard_negative": "Queries with explicit same-family or close-neighbor hard negative images."
  },

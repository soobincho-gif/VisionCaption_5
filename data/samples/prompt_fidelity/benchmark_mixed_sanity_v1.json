{
  "name": "prompt_fidelity_mixed_sanity_v1",
  "image_dir": "data/samples/prompt_fidelity/images",
  "notes": "Broader mixed sanity set for validating the frozen hard-benchmark winner without further tuning. It combines carried-over hard UI/screenshot disambiguation queries with new, easier UI, photo, and illustration prompts over the same fixed 12-image pool.",
  "query_tag_taxonomy": {
    "ui_family_disambiguation": "Queries that must distinguish related UI screens from the same product family.",
    "visible_text": "Queries where exact or near-exact visible words, labels, or short phrases should help retrieval.",
    "layout_structure": "Queries where panels, cards, transcript areas, or control layout should help retrieval.",
    "person_name": "Queries that rely on a named historical figure or persona identity.",
    "paraphrase": "Queries whose wording differs materially from the likely caption or visible text.",
    "photo_scene": "Queries for real-world photo scenes.",
    "illustration_style": "Queries that rely on drawn or painted visual style.",
    "partial_cue": "Queries that mention only a subset of discriminative cues.",
    "hard_negative": "Queries with explicit close-neighbor hard negatives from the same UI family."
  },
  "slice_taxonomy": {
    "hard_ui": "Carried-over hard UI/screenshot disambiguation cases from the curated hard benchmark.",
    "normal_ui": "New easier UI/screenshot sanity checks over the same sibling screen families.",
    "photo_or_illustration": "New real-photo or illustration sanity checks."
  },
